# KIS API (한국투자증권)
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=your_account_no
KIS_HTS_USER_ID=your_hts_id
KIS_PAPER_TRADING=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_CHAT_ID=your_chat_id

# Server
PORT=3001
WEB_PORT=3000

# 단일 사용자 (Firestore userId/accountId 대체)
USER_ID=default_user
ACCOUNT_ID=default_account
